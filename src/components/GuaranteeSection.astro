---
import type { HomePage } from "@/payload-types";
import type { Populated } from "@/utils/typeChecks";
import Image from "./Image.tsx";
import FigText from "./FigText.astro";

type Props = { home: Populated<HomePage> };
const { home } = Astro.props;
---

<section class="w-container mx-auto my-16 max-w-400">
  <div class="mx-auto w-full gap-4">
    <div class="flex flex-col lg:flex-row">
      <section
        class="col-span-1 min-h-125 lg:col-span-3 lg:min-h-150 xl:min-h-75"
      >
        <div class="relative h-full p-2 md:p-3">
          <div
            class="relative z-20 flex h-full flex-col gap-6 px-4 py-20 sm:px-10"
          >
            <FigText class="absolute -mt-4 -translate-y-full">FIG. 1.1</FigText>
            <div class="gap-4 text-3xl font-bold text-pretty lg:text-5xl">
              <span>
                {home.trust_subtitle}
              </span>
              <span class="text-gray-400">{home.trust_title}</span>
            </div>

            <p class="max-w-prose text-lg text-pretty">
              {home.trust_description}
            </p>

            <div></div>
            <div
              class="bg-stripes-diagonal relative flex flex-col gap-3 border border-gray-900 p-6 px-8"
            >
              <FigText class="absolute right-8 bottom-6 text-gray-700"
                >FIG. 1.2</FigText
              >
              <span class="text-2xl font-medium lg:text-3xl">
                {home.guarantee_title}
              </span>
              <p class="text-lg text-balance">{home.guarantee}</p>
            </div>
          </div>
        </div>
      </section>

      <div class="col-span-1 h-full min-h-125 lg:col-span-2 lg:min-h-75">
        <div class="relative h-full p-2 md:p-3">
          <div class="relative z-20 h-full px-4 py-20 sm:px-10">
            <div class="flex flex-col gap-6">
              <h1 class="text-3xl font-bold lg:text-4xl">
                {home.awards_title}
              </h1>
              <div class="z-10 flex w-full flex-wrap gap-8">
                {
                  home.awards?.map((awardImage) => (
                    <Image
                      media={awardImage}
                      width={175}
                      alt={""}
                      className="shrink max-w-[45%]! xs:max-w-full"
                    />
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

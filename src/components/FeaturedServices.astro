---
import { getPayload } from "@/payload";
import type { Service } from "@/payload-types";
import type { Populated } from "@/utils/typeChecks";
import { FeaturedServicesList } from "./FeaturedServicesList.tsx";

const payload = await getPayload();

const services = (
  await payload.find({ collection: "services", limit: 100, sort: "_order" })
).docs as Populated<Service>[];
---

<FeaturedServicesList services={services} client:visible />

---
import "../styles/global.css";

import Header from "@/components/Header";
import BaseHead from "../components/BaseHead.astro";
import Font from "astro/components/Font.astro";
import Footer from "@/components/Footer.astro";

type Props = Parameters<typeof BaseHead>["0"] & {
  title?: string;
  description?: string;
  header?: {
    appearance?: "sticky" | "fixed" | "overlay";
  };
  footer?: {
    hide?: boolean;
  };
  className?: string;
};

const {
  title,
  description,
  header = { appearance: "sticky" },
  footer = { hide: false },
  className = "",
  ...headProps
} = Astro.props;
---

<html
  lang="en"
  class:list={[
    "font-[--font-montserrat]",
    "bg-background text-foreground no-scrollbar min-h-full font-sans font-normal",
    className,
  ]}
>
  <head>
    <BaseHead title={title} description={description} {...headProps} />
    <Font cssVariable="--font-montserrat" preload />
  </head>

  <body class="no-scrollbar size-full">
    <Header currentPath={Astro.url.pathname} {...header} client:load />
    <main class="size-full">
      <slot />
    </main>
    {!footer.hide && <Footer />}
  </body>
</html>
